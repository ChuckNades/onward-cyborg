#!/bin/sh
set -eu

export DISPLAY="${DISPLAY:-:0}"
HDMI_OUTPUT="${CYBORG_HDMI_OUTPUT:-HDMI-1}"
TOUCH_DEVICE="${CYBORG_TOUCH_DEVICE:-Acer UT222Q}"

xrandr --output "$HDMI_OUTPUT" --rotate left || true
xinput set-prop "$TOUCH_DEVICE" "Coordinate Transformation Matrix" 0 -1 1 1 0 0 0 0 1 || true
unclutter -idle 0.5 -root &

# NOTE: an autologin kiosk never unlocks the GNOME login keyring, so without
# --password-store=basic Chromium throws a keyring-unlock dialog over the kiosk.
# (On Pi OS trixie the binary is `chromium`, not `chromium-browser` — reconcile
# during the Pi 5 / Touch Display 2 provisioning pass; see docs/deploy-notes.md.)
chromium-browser \
  --kiosk \
  --password-store=basic \
  --noerrdialogs \
  --disable-infobars \
  --incognito \
  --disable-extensions \
  --disable-gpu-compositing \
  --disable-features=Translate \
  --autoplay-policy=no-user-gesture-required \
  --check-for-update-interval=31536000 \
  --overscroll-history-navigation=0 \
  --force-device-scale-factor=1 \
  http://127.0.0.1:8765/
